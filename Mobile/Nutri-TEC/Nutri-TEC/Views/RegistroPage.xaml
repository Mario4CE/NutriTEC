<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Nutri_TEC.Views.RegistroPage"
             Title="Registrarse"
             BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1f1f1f}">

    <ScrollView BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1f1f1f}">
        <VerticalStackLayout Padding="20" Spacing="15" BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1f1f1f}">
            <!-- Email -->
            <VerticalStackLayout Spacing="5" BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1f1f1f}">
                <Label Text="Correo Electrónico" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}"/>
                <Border Padding="12,8" Stroke="#ddd" StrokeThickness="1" StrokeShape="RoundRectangle 8,8,8,8" Background="{AppThemeBinding Light=White, Dark=#2a2a2a}">
                    <Entry x:Name="EmailEntry" Placeholder="tu@correo.com" Keyboard="Email" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}" PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" Background="Transparent"/>
                </Border>
            </VerticalStackLayout>

            <!-- Nombre -->
            <VerticalStackLayout Spacing="5" BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1f1f1f}">
                <Label Text="Nombre Completo" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}"/>
                <Border Padding="12,8" Stroke="#ddd" StrokeThickness="1" StrokeShape="RoundRectangle 8,8,8,8" Background="{AppThemeBinding Light=White, Dark=#2a2a2a}">
                    <Entry x:Name="NombreEntry" Placeholder="Juan Pérez" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}" PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" Background="Transparent"/>
                </Border>
            </VerticalStackLayout>

            <!-- Contraseña -->
            <VerticalStackLayout Spacing="5" BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1f1f1f}">
                <Label Text="Contraseña" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}"/>
                <Border Padding="12,8" Stroke="#ddd" StrokeThickness="1" StrokeShape="RoundRectangle 8,8,8,8" Background="{AppThemeBinding Light=White, Dark=#2a2a2a}">
                    <Entry x:Name="ContraseñaEntry" Placeholder="••••••••" IsPassword="True" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}" PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" Background="Transparent"/>
                </Border>
            </VerticalStackLayout>

            <!-- Confirmar Contraseña -->
            <VerticalStackLayout Spacing="5" BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1f1f1f}">
                <Label Text="Confirmar Contraseña" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}"/>
                <Border Padding="12,8" Stroke="#ddd" StrokeThickness="1" StrokeShape="RoundRectangle 8,8,8,8" Background="{AppThemeBinding Light=White, Dark=#2a2a2a}">
                    <Entry x:Name="ConfirmarContraseñaEntry" Placeholder="••••••••" IsPassword="True" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}" PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" Background="Transparent"/>
                </Border>
            </VerticalStackLayout>

            <!-- Peso -->
            <VerticalStackLayout Spacing="5" BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1f1f1f}">
                <Label Text="Peso (kg)" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}"/>
                <Border Padding="12,8" Stroke="#ddd" StrokeThickness="1" StrokeShape="RoundRectangle 8,8,8,8" Background="{AppThemeBinding Light=White, Dark=#2a2a2a}">
                    <Entry x:Name="PesoEntry" Placeholder="75" Keyboard="Numeric" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}" PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" Background="Transparent"/>
                </Border>
            </VerticalStackLayout>

            <!-- Estatura -->
            <VerticalStackLayout Spacing="5" BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1f1f1f}">
                <Label Text="Estatura (cm)" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}"/>
                <Border Padding="12,8" Stroke="#ddd" StrokeThickness="1" StrokeShape="RoundRectangle 8,8,8,8" Background="{AppThemeBinding Light=White, Dark=#2a2a2a}">
                    <Entry x:Name="EstaturaEntry" Placeholder="175" Keyboard="Numeric" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}" PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" Background="Transparent"/>
                </Border>
            </VerticalStackLayout>

            <!-- Edad -->
            <VerticalStackLayout Spacing="5" BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1f1f1f}">
                <Label Text="Edad (años)" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}"/>
                <Border Padding="12,8" Stroke="#ddd" StrokeThickness="1" StrokeShape="RoundRectangle 8,8,8,8" Background="{AppThemeBinding Light=White, Dark=#2a2a2a}">
                    <Entry x:Name="EdadEntry" Placeholder="30" Keyboard="Numeric" TextColor="{AppThemeBinding Light=#333333, Dark=#e0e0e0}" PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}" Background="Transparent"/>
                </Border>
            </VerticalStackLayout>

            <!-- Botón Registrarse -->
            <Button Text="Registrarse" 
                    Clicked="OnRegistrarse"
                    Background="#2ecc71"
                    TextColor="White"
                    Padding="16,12"
                    CornerRadius="8"
                    FontSize="16"
                    FontAttributes="Bold"
                    Margin="0,20,0,0"/>

            <!-- Botón Volver -->
            <Button Text="Volver al Login" 
                    Clicked="OnVolver"
                    Background="{AppThemeBinding Light=White, Dark=#2a2a2a}"
                    TextColor="#2ecc71"
                    BorderColor="#2ecc71"
                    BorderWidth="2"
                    Padding="16,12"
                    CornerRadius="8"
                    FontSize="14"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
